#!/usr/bin/env ruby
# frozen_string_literal: true

require "json"
require "optparse"
require_relative "../lib/partitura/framework"

parser = OptionParser.new do |opts|
  opts.banner = "Usage: partitura_build REGISTRY.rb [movement|all]"
end
parser.parse!

registry_path = ARGV.shift
movement = ARGV.shift || "all"
if registry_path.nil?
  warn parser
  exit 2
end

begin
  registry = Sigillum::Framework::Registry.load_file(registry_path)
  paths = registry.write_transport(movement)
  puts JSON.pretty_generate(transports: paths.map(&:to_s))
rescue Sigillum::OrchestralDSL::Production::CompileError => e
  warn JSON.pretty_generate(e.response)
  exit 1
rescue KeyError => e
  warn e.message
  exit 1
end
