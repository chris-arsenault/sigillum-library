#!/usr/bin/env ruby
# frozen_string_literal: true

require "fileutils"
require "json"
require "open3"
require "optparse"
require_relative "../lib/sigillum/orchestral_dsl"

options = {
  stem: nil,
  transport_only: false
}

parser = OptionParser.new do |opts|
  opts.banner = "Usage: production_export SOURCE.rb [--stem STEM] [--transport-only]"
  opts.on("--stem STEM", "Output stem; defaults to the source filename") { |value| options[:stem] = value }
  opts.on("--transport-only", "Write only the JSON transport") { options[:transport_only] = true }
end

parser.parse!
source = ARGV.shift

if source.nil?
  warn parser
  exit 2
end

stem = options[:stem] || File.basename(source, File.extname(source))

# Derive output dir: outputs/<namespace>/<stem>/
# Source must live inside a dsl/ directory; output mirrors the path above that.
repo_root = `git -C #{File.dirname(File.expand_path(source))} rev-parse --show-toplevel`.chomp
source_abs = File.expand_path(source)
source_rel = source_abs.delete_prefix("#{repo_root}/")
source_dir = File.dirname(source_rel)

unless File.basename(source_dir) == "dsl"
  warn "production_export: source must live inside a dsl/ directory (got: #{source_dir})"
  exit 2
end

namespace = File.dirname(source_dir)
out_dir = File.join(repo_root, "outputs", namespace, stem)
FileUtils.mkdir_p(out_dir)

begin
  piece = Sigillum::OrchestralDSL.load_production_file(source)
  transport = Sigillum::OrchestralDSL.production_transport_hash(piece)
rescue Sigillum::OrchestralDSL::Production::CompileError => e
  warn JSON.pretty_generate(e.response)
  exit 1
end

if transport[:status] == "error"
  warn JSON.pretty_generate(transport)
  exit 1
end

transport_path = File.join(out_dir, "#{stem}.sigillum_transport.json")
File.write(transport_path, JSON.pretty_generate(transport))

result = { transport: transport_path }

unless options[:transport_only]
  stdout, stderr, status = Open3.capture3(
    "python",
    "-m",
    "framework.orchestral_dsl_transport",
    transport_path,
    out_dir,
    "--stem",
    stem
  )
  unless status.success?
    warn stderr
    warn stdout unless stdout.empty?
    exit status.exitstatus
  end
  result[:musicxml] = File.join(out_dir, "#{stem}.musicxml")
  result[:midi] = File.join(out_dir, "#{stem}.mid")
end

puts JSON.pretty_generate(result)
